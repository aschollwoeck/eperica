# Normalize line endings: LF in the repo and working tree for all text files.
* text=auto eol=lf

*.rs   text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# Binary assets
*.docx binary
*.png  binary
*.jpg  binary
*.ico  binary
*.svg  text eol=lf
