# Copy to .env for local development (.env is git-ignored).

# PostgreSQL connection string (required).
DATABASE_URL=postgres://eperica:eperica@localhost:5432/eperica

# World configuration (P7). Defaults: WORLD_SPEED=1, WORLD_RADIUS=200.
WORLD_SPEED=1
WORLD_RADIUS=200

# Logging filter for the tracing subscriber.
RUST_LOG=info

# Cookie encryption key — REQUIRED in production, must be >= 64 bytes. If unset, an ephemeral key is
# generated per process (sessions won't survive restart and won't work across multiple instances).
# SESSION_SECRET=change-me-to-a-long-random-string-of-at-least-64-bytes-................

# Set to 1/true to require email confirmation before first login (default: off in dev).
# REQUIRE_EMAIL_CONFIRMATION=false

# Address the web server binds to (default 127.0.0.1:8080).
# BIND_ADDR=127.0.0.1:8080

# Seconds after world creation when end-game artifacts release (020). Default 90 days.
ARTIFACT_RELEASE_DELAY_SECS=7776000

# Seconds after world creation when Wonder plans + sites release (021). Default 120 days.
WONDER_RELEASE_DELAY_SECS=10368000

# Comma-separated usernames granted the Moderator role at startup (022). Unset ⇒ no moderators.
# MODERATORS=alice,bob

# Comma-separated usernames granted the Administrator role at startup (036). Unset ⇒ no admins.
# Ensures at least one admin via config even if all in-app admins are demoted.
# ADMINS=alice

# Trust X-Forwarded-For / X-Real-IP for the client IP (022). Enable ONLY behind a trusted reverse
# proxy; otherwise the headers are spoofable and the peer address is used. Default false.
# TRUST_PROXY=false
